{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sandbox-website-template",
  "compatibility_date": "2025-10-08",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": "./src/api/index.ts",
  "observability": {
    "enabled": true
  },
  "upload_source_maps": true,
  "assets": {
    "directory": "./dist/client",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/api/*"
    ]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "qhek59hodgvu1irr1j45lr3t3v6oi3z8",
      "database_id": "459b630e-df44-44c2-8fb4-9049fdd94268",
      "migrations_dir": "src/api/migrations"
    }
  ],
  "r2_buckets": [
    {
      "bucket_name": "qhek59hodgvu1irr1j45lr3t3v6oi3z8",
      "binding": "BUCKET"
    }
  ],
  "vars": {
    "OPENAI_API_KEY": ""
  }
}